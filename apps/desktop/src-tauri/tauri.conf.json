{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi Remote",
  "version": "0.1.0",
  "identifier": "dev.piremote.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "Pi Remote", "width": 1360, "height": 900, "minWidth": 820, "minHeight": 620 }],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: http: https:; connect-src 'self' ws: wss: http: https:; frame-src http: https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": { "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true } }
  }
}
